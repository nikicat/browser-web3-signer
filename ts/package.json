{
  "name": "browser-web3-signer",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript binding (viem transport + account) over the browser-web3-signer control API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikicat/browser-web3-signer.git",
    "directory": "ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "node --test --import tsx ./test/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "viem": "^2.48.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
